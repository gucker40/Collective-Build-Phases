{
  "name": "logos-app",
  "productName": "The Collective",
  "version": "1.0.0",
  "description": "Logos - Logos AI Council",
  "main": "electron.js",
  "scripts": {
    "dev": "concurrently \"vite --host\" \"wait-on http://localhost:5173 && electron .\"",
    "build:vite": "vite build",
    "build:app": "npm run build:vite && electron-builder --config electron-builder.json",
    "build": "npm run build:app",
    "pack": "npm run build:vite && electron-builder --dir --config electron-builder.json",
    "dist": "npm run build:vite && electron-builder --win --config electron-builder.json"
  },
  "dependencies": {
    "framer-motion": "^11.1.0",
    "lucide-react": "^0.383.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-syntax-highlighter": "^15.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
